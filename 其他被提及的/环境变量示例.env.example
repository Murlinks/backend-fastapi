# 应用配置
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# 数据库配置
DATABASE_URL=postgresql://finance_user:finance_pass@localhost:5432/finance_db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# DeepSeek API配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com

# 短信服务配置
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key

# 微信支付配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key

# 百度OCR配置
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key

# 百度语音配置
BAIDU_VOICE_API_KEY=your-baidu-voice-api-key
BAIDU_VOICE_SECRET_KEY=your-baidu-voice-secret-key

# Webhook配置
WEBHOOK_SECRET=your-webhook-secret-key

# 第三方集成系统配置
INTEGRATIONS_ENABLED=true
INTEGRATIONS_AUTO_INIT=true