# 生产环境配置示例
# 复制此文件为 .env.prod 并填入实际值

# 数据库配置
DB_PASSWORD=your_secure_db_password_here

# 应用密钥
SECRET_KEY=your_secret_key_here_at_least_32_characters_long

# AI服务配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Redis配置
REDIS_PASSWORD=your_redis_password_here

# 监控配置
GRAFANA_PASSWORD=your_grafana_admin_password_here

# 微信支付配置
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# 支付宝配置
ALIPAY_APP_ID=your_alipay_app_id_here
ALIPAY_PRIVATE_KEY=your_alipay_private_key_here

# 短信服务配置
SMS_ACCESS_KEY=your_sms_access_key_here
SMS_SECRET_KEY=your_sms_secret_key_here

# 域名配置（用于SSL证书）
DOMAIN_NAME=your-domain.com

# 邮件配置（用于告警通知）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@your-domain.com
SMTP_PASSWORD=your_email_password_here

# 对象存储配置（可选）
OSS_ACCESS_KEY=your_oss_access_key_here
OSS_SECRET_KEY=your_oss_secret_key_here
OSS_BUCKET=your_bucket_name_here
OSS_ENDPOINT=your_oss_endpoint_here